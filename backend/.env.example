# ─────────────────────────────────────────────────────────────
# Certo backend — environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# App
ENV=local                       # local | staging | production
DEBUG=true
API_PREFIX=/api/v1

# CORS — origins your frontend runs on (comma-separated).
# Next.js/CRA -> 3000, Vite -> 5173. Add your prod domain when deployed.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (async driver). Postgres for deploys; for a zero-infra local run use SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./certo.db
DATABASE_URL=postgresql+asyncpg://certo:certo@localhost:5432/certo

# Background execution. true = run evaluations/trace-scoring in-process (no Redis
# needed — the zero-infra local mode). false = enqueue to Arq + Redis worker.
RUN_WORKER_INLINE=true

# Redis (only used when RUN_WORKER_INLINE=false)
REDIS_URL=redis://localhost:6379/0

# ── AMD / Fireworks AI — the flagship integration (3 models on AMD) ──
# Get a key at https://fireworks.ai/account/api-keys. MODEL + MODEL_2 = a real
# 2-judge ensemble (consensus + disagreement); FIXER_MODEL is the third model that
# generates the remediation for the "Generate fix" action. Leave FIREWORKS_API_KEY
# empty to run in demo mode (deterministic checks only). Use a Gemma model for the bonus.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_MODEL_2=accounts/fireworks/models/glm-5p2
FIREWORKS_FIXER_MODEL=accounts/fireworks/models/deepseek-v4-pro

# ── E2B sandbox ──────────────────────────────────────────────
E2B_API_KEY=                    # https://e2b.dev — leave empty to use MOCK_SANDBOX
MOCK_SANDBOX=true               # true: run code locally/stubbed instead of real E2B

# ── Judge #1: self-hosted vLLM (any OpenAI-compatible endpoint) ──
# Point this at your GPU box / tunnel (e.g. qwen3.6-27b on vLLM).
JUDGE_BASE_URL=http://localhost:8000/v1
JUDGE_API_KEY=EMPTY             # vLLM ignores it but openai client requires a value
JUDGE_MODEL=qwen3.6-27b
MOCK_JUDGE=true                 # true: deterministic stub score instead of real model
# Reasoning models "think" before answering (slow, token-hungry). Grading is
# rubric-driven, so thinking stays off (~7x faster). Set false to re-enable.
JUDGE_DISABLE_THINKING=true
# Comma-separated backup judge URLs — if a call fails (e.g. an ephemeral tunnel
# rotated) the judge auto-rotates to the next one. Health check: scripts.check_judge
JUDGE_FALLBACK_BASE_URLS=

# ── Judge: Anthropic Claude (optional primary, replaces the vLLM judge) ──
# Set ENABLED=true to grade with Claude instead of the vLLM judge.
# "Sonnet 3.5" is retired (404) -> claude-sonnet-4-6 is the drop-in successor.
JUDGE_ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
JUDGE_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Judge #2: secondary LLM judge (ensemble, removes subjectivity) ──
# >>> PLUG IN ANOTHER LLM HERE <<<  Any OpenAI-compatible endpoint.
# Set ENABLED=true and fill in the 3 lines below to activate a 2-judge ensemble.
JUDGE_SECONDARY_ENABLED=false
JUDGE_SECONDARY_BASE_URL=https://api.openai.com/v1
JUDGE_SECONDARY_API_KEY=
JUDGE_SECONDARY_MODEL=gpt-4o-mini

# ── Agent-under-test default inference (can be overridden per-agent) ──
AGENT_DEFAULT_BASE_URL=https://api.openai.com/v1
AGENT_DEFAULT_API_KEY=
AGENT_DEFAULT_MODEL=gpt-4o-mini

# ── Scoring ──────────────────────────────────────────────────
REWARD_PASS_THRESHOLD=4         # judge score (1-5) >= threshold -> reward +1, else -1
# TrustScore blend  q = c * (TRUST_BETA + (1-TRUST_BETA)*P)  — see docs/TRUSTSCORE.md.
# Correctness c is a hard gate; TRUST_BETA = floor a correct-but-messy run keeps;
# TRUST_LAMBDA splits step-quality vs holistic inside P. Calibrate: scripts.calibrate_trustscore
TRUST_BETA=0.4
TRUST_LAMBDA=0.4
# Trajectory axis cost control: grade at most this many spans per task.
JUDGE_GRADE_STEPS=true
JUDGE_SPAN_LIMIT=12
# Seconds an agent gets per task (browsing agents need minutes, not 90s).
AGENT_REQUEST_TIMEOUT=600

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production        # signs JWTs + login codes — set a long random value
ACCESS_TOKEN_DAYS=30
FRONTEND_URL=http://localhost:3000        # where Google OAuth redirects back to

# Login-code email delivery: "console" (dev: code printed in log + shown in UI) or "smtp"
EMAIL_MODE=console
EMAIL_FROM=Certo <no-reply@certo.local>
# Fill these in and set EMAIL_MODE=smtp to send real emails (e.g. Gmail app password):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# "Continue with Google" — create an OAuth client at console.cloud.google.com,
# add redirect URI:  http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
